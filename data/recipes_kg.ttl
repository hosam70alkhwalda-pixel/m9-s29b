@prefix : <http://aispire.example.org/recipes/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ---- Classes ----
:Ingredient a rdfs:Class ; rdfs:label "Ingredient" .
:Color a rdfs:Class ; rdfs:label "Color" .
:Cuisine a rdfs:Class ; rdfs:label "Cuisine" .
:Author a rdfs:Class ; rdfs:label "Author" .
:Recipe a rdfs:Class ; rdfs:label "Recipe" .

# ---- Cuisine subclass hierarchy ----
:European a :Cuisine ; skos:prefLabel "european" .
:Asian a :Cuisine ; skos:prefLabel "asian" .
:Italian a :Cuisine ; rdfs:subClassOf :European ; skos:prefLabel "italian" .
:French a :Cuisine ; rdfs:subClassOf :European ; skos:prefLabel "french" .
:Greek a :Cuisine ; rdfs:subClassOf :European ; skos:prefLabel "greek" ; skos:altLabel "hellenic" .
:Thai a :Cuisine ; rdfs:subClassOf :Asian ; skos:prefLabel "thai" ; skos:altLabel "siamese" .
:Japanese a :Cuisine ; rdfs:subClassOf :Asian ; skos:prefLabel "japanese" .
:Mexican a :Cuisine ; skos:prefLabel "mexican" .
:turkeyCuisine a :Cuisine ; skos:prefLabel "turkish" ; skos:altLabel "turkey" .

# ---- Ingredients ----
:eggplant a :Ingredient ; skos:prefLabel "eggplant" ; skos:altLabel "aubergine" .
:basil a :Ingredient ; skos:prefLabel "basil" ; skos:altLabel "sweet basil" .
:salt a :Ingredient ; skos:prefLabel "salt" .
:parmesan a :Ingredient ; skos:prefLabel "parmesan" ; skos:altLabel "parmigiano" .
:tomato a :Ingredient ; skos:prefLabel "tomato" .
:garlic a :Ingredient ; skos:prefLabel "garlic" .
:orangeFruit a :Ingredient ; skos:prefLabel "orange" ; skos:altLabel "naranja" .
:turkeyMeat a :Ingredient ; skos:prefLabel "turkey" ; skos:altLabel "tom" .

# ---- Colors (ambiguity sources) ----
:orangeColor a :Color ; skos:prefLabel "orange" ; skos:altLabel "amber" .

# ---- Authors ----
:annaAuthor a :Author ; skos:prefLabel "anna" .
:sarahAuthor a :Author ; skos:prefLabel "sarah" .
:marcoAuthor a :Author ; skos:prefLabel "marco" .
:yukiAuthor a :Author ; skos:prefLabel "yuki" .
:rajAuthor a :Author ; skos:prefLabel "raj" .

